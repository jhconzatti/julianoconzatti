{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/en",
      "destination": "/en.html"
    },
    {
      "source": "/en/",
      "destination": "/en.html"
    },
    {
      "source": "/es",
      "destination": "/es.html"
    },
    {
      "source": "/es/",
      "destination": "/es.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}